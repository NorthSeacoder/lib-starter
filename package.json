{
  "name": "@nsea/starter",
  "version": "0.0.0",
  "description": "🚀 现代化 TypeScript 库开发模板 - 包含完整的开发环境、构建工具和最佳实践配置",
  "keywords": [
    "template",
    "typescript",
    "library",
    "cli",
    "starter",
    "development"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "packageManager": "pnpm@11.1.3",
  "bin": {
    "starter": "bin/starter.cjs"
  },
  "main": "dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "homepage": "https://github.com/NorthSeacoder/lib-starter/README.md",
  "bugs": {
    "url": "https://github.com/NorthSeacoder/lib-starter/issues"
  },
  "author": "NorthSeacoder",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NorthSeacoder/lib-starter.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "sideEffects": false,
  "type": "module",
  "devDependencies": {
    "@antfu/ni": "^30.1.0",
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.0",
    "@vitest/coverage-v8": "^4.1.6",
    "@vitest/ui": "^4.1.6",
    "bumpp": "^11.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild-visualizer": "^0.7.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "execa": "^9.6.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "tsdown": "^0.22.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "scripts": {
    "prepare": "simple-git-hooks",
    "cz": "git add . && git-cz",
    "clean": "rimraf dist stats.html",
    "dev": "tsx src/cli/run.ts",
    "dev:watch": "tsx watch src/cli/run.ts",
    "start": "node bin/starter.cjs",
    "build:js": "tsdown",
    "build:types": "tsc -p tsconfig.build.json && node -e \"import('node:fs/promises').then(fs => fs.copyFile('dist/index.d.ts', 'dist/index.d.cts'))\"",
    "build": "nr clean && pnpm build:js && pnpm build:types",
    "build:watch": "tsdown --watch",
    "analyze": "nr clean && tsdown --metafile && esbuild-visualizer --metadata ./dist/metafile-*.json --open",
    "lint": "eslint src --fix",
    "lint:check": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src",
    "test:e2e": "vitest run test/e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-exports": "pnpm build && publint",
    "check-exports:fast": "publint",
    "check-exports:attw": "attw --pack .",
    "typecheck": "tsc --noEmit",
    "ci": "nr lint:check && nr format:check && nr typecheck && nr test:coverage && nr build && nr check-exports:fast",
    "verify:release": "nr lint:check && nr typecheck && nr test && nr build && nr check-exports:fast",
    "prepublishOnly": "npm run ci",
    "release": "bumpp",
    "release:publish": "npm publish",
    "postinstall": "simple-git-hooks"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
